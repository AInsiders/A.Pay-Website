# Copy to .env and fill in (local dev: bank-portal/.env)
# Full setup checklist: ../SETUP.md
# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Teller Connect (optional until you test bank linking)
VITE_TELLER_APP_ID=
# sandbox = fake banks | development | production = real institutions (match Teller Dashboard app mode)
VITE_TELLER_ENVIRONMENT=development
